---
import { mainNav } from "../data/nav";

const currentPath = Astro.url.pathname;
---

<header class="border-b border-border bg-background/95">
  <div class="max-w-4xl mx-auto px-6 md:px-8 py-4 md:py-5 flex items-center justify-between gap-6">
    <a
      href="/"
      class="font-serif text-[1.0625rem] font-bold tracking-tight text-foreground hover:text-accent transition-colors duration-150"
    >
      Alban Jerome
    </a>
    <nav class="flex items-center gap-5 md:gap-7 flex-wrap justify-end" aria-label="Main">
      {
        mainNav.map((item) => {
          const active =
            currentPath === item.href ||
            (item.href !== "/" && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                "text-[13px] tracking-wide transition-colors duration-150",
                active
                  ? "text-foreground font-medium"
                  : "text-muted-foreground hover:text-foreground",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
