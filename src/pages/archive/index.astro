---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArchiveYears } from "../../lib/posts";

const years = await getArchiveYears();
---

<BaseLayout
  title="Archive"
  description="Browse archived essays by year."
  path="/archive"
>
  <h1 class="font-serif text-3xl font-bold tracking-tight mb-2">Archive</h1>
  <p class="text-sm text-muted-foreground mb-10">
    Earlier writing on education, entrepreneurship, and emerging ideas.
  </p>

  <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
    {
      years.map((item) => (
        <a
          href={`/archive/${item.year}`}
          class="group block p-5 border border-border rounded-lg hover:border-accent/40 transition-colors"
        >
          <h2 class="font-serif text-2xl font-bold group-hover:text-accent transition-colors">
            {item.year}
          </h2>
          <p class="text-sm text-muted-foreground mt-1">
            {item.count} {item.count === 1 ? "essay" : "essays"}
          </p>
        </a>
      ))
    }
  </div>
</BaseLayout>
