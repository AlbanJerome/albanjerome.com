---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" path="/404">
  <div class="py-16 text-center">
    <h1 class="font-serif text-2xl font-bold mb-4">Page not found</h1>
    <p class="text-sm text-muted-foreground mb-8">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a href="/" class="text-sm text-accent hover:underline">Return home →</a>
  </div>
</BaseLayout>
